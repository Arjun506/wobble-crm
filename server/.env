# ==========================================
# WOBBLE CRM - MESSAGING CONFIGURATION
# ==========================================

# --- YOUR SENDER DETAILS ---
# Your business email and WhatsApp number for reference
WOBBLE_EMAIL_SENDER=support@wobble.in
WOBBLE_WHATSAPP_NUMBER=8123889977

# ==========================================
# OPTION 1: SMTP EMAIL (Recommended for support@wobble.in)
# ==========================================
# To send REAL emails from support@wobble.in, you need SMTP credentials
# from your email hosting provider (Google Workspace, Zoho, GoDaddy, etc.)
# Example for Google Workspace / Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=support@wobble.in
#   SMTP_PASS=your_app_password_here
#   SMTP_FROM=support@wobble.in
#
# Example for Zoho Mail:
#   SMTP_HOST=smtp.zoho.in
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=support@wobble.in
#   SMTP_PASS=your_zoho_password
#   SMTP_FROM=support@wobble.in

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=support@wobble.in

# ==========================================
# OPTION 2: EMAILJS (Alternative email)
# ==========================================
# Get from https://dashboard.emailjs.com/admin
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# ==========================================
# TWILIO - FOR REAL SMS & WHATSAPP
# ==========================================
# NOTE: You cannot use 8123889977 directly with Twilio.
# You must either:
#   A) Buy a Twilio phone number (recommended for SMS)
#   B) Apply for Twilio WhatsApp Business API with your number 8123889977
# Sign up at: https://www.twilio.com/try-twilio
# Get credentials from: https://console.twilio.com/

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
# This must be a Twilio number you purchased, NOT 8123889977
TWILIO_PHONE_NUMBER=+1234567890
# Optional: separate Twilio WhatsApp sender number
TWILIO_WHATSAPP_NUMBER=

# ==========================================
# SERVER PORT
# ==========================================
PORT=5000

